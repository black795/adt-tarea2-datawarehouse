{
	"name": "gold_dim_tiempo",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_ventas_consolidadas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n        CAST(CONVERT(VARCHAR(8), CAST(s.fecha_venta AS DATE), 112) AS INT) AS fecha_key,\\n        CAST(s.fecha_venta AS DATE) AS fecha,\\n        DATEPART(WEEKDAY, s.fecha_venta) AS dia_semana,\\n        DATENAME(WEEKDAY, s.fecha_venta) AS nombre_dia,\\n        DAY(s.fecha_venta) AS dia_mes,\\n        MONTH(s.fecha_venta) AS mes,\\n        DATENAME(MONTH, s.fecha_venta) AS nombre_mes,\\n        DATEPART(QUARTER, s.fecha_venta) AS trimestre,\\n        YEAR(s.fecha_venta) AS anio,\\n        CASE \\n            WHEN DATEPART(WEEKDAY, s.fecha_venta) IN (6, 7) THEN 1 \\n            ELSE 0 \\n        END AS es_fin_semana\\n    FROM (\\n        SELECT DISTINCT CAST(fecha_venta AS DATE) AS fecha_venta\\n        FROM silver.ventas_consolidadas\\n        WHERE fecha_venta IS NOT NULL) s\\n\\n',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_key,",
				"          fecha,",
				"          dia_semana,",
				"          nombre_dia,",
				"          dia_mes,",
				"          mes,",
				"          nombre_mes,",
				"          trimestre,",
				"          anio",
				"     )) ~> sink1"
			]
		}
	}
}