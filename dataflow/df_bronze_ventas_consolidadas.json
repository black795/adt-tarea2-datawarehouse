{
	"name": "df_bronze_ventas_consolidadas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_sucursal_lpz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ventas_sucursal_scz_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "silver_inventario",
						"type": "DatasetReference"
					},
					"name": "source4"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_ventas_consolidadas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "union1"
				},
				{
					"name": "union2"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "derivedColumn6"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "select4"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Venta as string,",
				"          Fecha_Venta as string,",
				"          Producto as string,",
				"          Cant as string,",
				"          PrecioUnit as string,",
				"          Sucursal as string,",
				"          Vendedor as string,",
				"          NombreCliente as string,",
				"          EmailCliente as string,",
				"          MetodoPago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          codigo_producto as string,",
				"          nombre_producto as string,",
				"          categoria as string,",
				"          precio_venta as decimal(18,2),",
				"          costo_adquisicion as decimal(18,2),",
				"          stock_actual as integer,",
				"          sucursal as string,",
				"          proveedor as string,",
				"          ultima_reposicion as date,",
				"          activo as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source1 select(mapColumn(",
				"          id_transaccion_origen = ID_Venta,",
				"          fecha_venta = Fecha_Venta,",
				"          nombre_producto_original = Producto,",
				"          cantidad = Cant,",
				"          precio_unitario = PrecioUnit,",
				"          canal_venta = Sucursal,",
				"          cliente_nombre = NombreCliente,",
				"          metodo_pago = MetodoPago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source2 select(mapColumn(",
				"          id_transaccion_origen = id_venta,",
				"          fecha_venta = fecha,",
				"          nombre_producto_original = producto,",
				"          cantidad,",
				"          precio_unitario,",
				"          canal_venta = sucursal,",
				"          cliente_nombre,",
				"          metodo_pago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source3 select(mapColumn(",
				"          id_transaccion_origen = order_id,",
				"          fecha_venta = timestamp,",
				"          nombre_producto_original = product,",
				"          cantidad = qty,",
				"          precio_unitario = unit_price,",
				"          cliente_nombre = {customer/name},",
				"          metodo_pago = payment_method,",
				"          costo_envio = shipping_cost,",
				"          canal_venta = channel",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select1 derive(canal_venta = \"LPZ\") ~> derivedColumn1",
				"select2 derive(canal_venta = \"SCZ\") ~> derivedColumn2",
				"select3 derive(canal_venta = \"ONLINE\") ~> derivedColumn3",
				"derivedColumn1, derivedColumn2 union(byName: true)~> union1",
				"union1, derivedColumn3 union(byName: true)~> union2",
				"union2 derive(fecha_venta = coalesce(    toDate(fecha_venta, 'yyyy-MM-dd'),   \r",
				" toDate(fecha_venta, 'dd/MM/yyyy'),   \r",
				"  toDate(fecha_venta, 'MM-dd-yyyy'),   \r",
				"   toDate(fecha_venta, 'yyyy/MM/dd'),    \r",
				"   toDate(fecha_venta, 'dd-MMM-yyyy'),   \r",
				"    toDate(fecha_venta, 'MMMM dd, yyyy'),  \r",
				"      toDate(fecha_venta, 'dd-MM-yyyy'),   \r",
				"       toDate(      \r",
				"          regexReplace(fecha_venta, '(?i) de ', ' '),        'dd MMMM yyyy'    )),",
				"          precio_unitario = toDecimal(regexReplace(toString (precio_unitario), '[^0-9.]', '')),",
				"          nombre_producto_original = initCap(regexReplace(trim(nombre_producto_original),'\\\\s+',' ')),",
				"          cantidad = toInteger(cantidad)) ~> derivedColumn4",
				"derivedColumn4 derive(precio_unitario = iifNull(precio_unitario, 0.0, precio_unitario),",
				"          costo_envio = iifNull(costo_envio, \"0.0\", costo_envio),",
				"          cantidad = iifNull(cantidad, 0, cantidad)) ~> derivedColumn5",
				"derivedColumn5 derive(monto_total = precio_unitario * cantidad) ~> derivedColumn6",
				"derivedColumn6, source4 lookup(nombre_producto_original == nombre_producto,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 select(mapColumn(",
				"          id_transaccion_origen,",
				"          fecha_venta,",
				"          nombre_producto_original,",
				"          cantidad,",
				"          precio_unitario,",
				"          canal_venta,",
				"          cliente_nombre,",
				"          metodo_pago,",
				"          costo_envio,",
				"          monto_total,",
				"          codigo_producto",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"select4 filter(!isNull(codigo_producto)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_transaccion_origen as string,",
				"          fecha_venta as timestamp,",
				"          codigo_producto as string,",
				"          nombre_producto_original as string,",
				"          cantidad as integer,",
				"          precio_unitario as decimal(18,2),",
				"          monto_total as decimal(18,2),",
				"          canal_venta as string,",
				"          cliente_nombre as string,",
				"          metodo_pago as string,",
				"          costo_envio as decimal(18,2),",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_transaccion_origen,",
				"          fecha_venta,",
				"          codigo_producto,",
				"          nombre_producto_original,",
				"          cantidad,",
				"          precio_unitario,",
				"          monto_total,",
				"          canal_venta,",
				"          cliente_nombre,",
				"          metodo_pago,",
				"          costo_envio",
				"     )) ~> sink1"
			]
		}
	}
}